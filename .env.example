# Environment
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# External APIs
SALES_API_URL=http://localhost:3001
SERVICE_API_URL=http://localhost:3002

# Database (for future PostgreSQL implementation)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/keyloop
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=keyloop

# Swagger API Documentation
API_TITLE=Keyloop Document Viewer
API_VERSION=1.0.0
API_DESCRIPTION=Unified Document Viewer API

# CORS
CORS_ORIGIN=http://localhost:3000
